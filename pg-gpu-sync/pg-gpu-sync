#!/bin/bash

# ============================================================
#  PG GPU Sync — Equestria OS
#  Automated NVIDIA driver manager for Arch-based systems.
#
#  Compatible with: Equestria OS, pure Arch Linux.
#
#  Modes:
#    Interactive  — asks for confirmation (default)
#    --auto       — fully silent, for OS installer / live image
#    --test       — dry run, nothing is changed
# ============================================================

# ── Colour output ─────────────────────────────────────────────
_RED='\033[0;31m'
_YEL='\033[1;33m'
_GRN='\033[0;32m'
_CYN='\033[0;36m'
_RST='\033[0m'

Info()   { echo -e "${_GRN}[pg-gpu-sync]${_RST} $*"; }
Warn()   { echo -e "${_YEL}[WARNING]${_RST}     $*" >&2; }
DIE()    { echo -e "${_RED}[ERROR]${_RST}       $*" >&2; exit 1; }
Note()   { echo -e "${_CYN}[NOTE]${_RST}        $*"; }
Header() { echo -e "\n${_CYN}══════════════════════════════════════${_RST}\n  $*\n${_CYN}══════════════════════════════════════${_RST}"; }

# ── State file (для обнаружения смены GPU) ────────────────────
STATE_FILE=/var/lib/pg-gpu-sync/gpu-family

# ── Offline driver cache ───────────────────────────────────────
# Pre-built .pkg.tar.zst files can be placed here (e.g. in the ISO image).
# When found, they are used instead of downloading from the internet.
DRIVER_CACHE_DIR=/usr/share/pg-gpu-sync/drivers

GpuChanged() {
    [ ! -f "$STATE_FILE" ] && return 0
    [ "$(cat "$STATE_FILE")" != "$GPU_FAMILY" ]
}

SaveGpuState() {
    [ "$DRY_RUN" = yes ] && return
    mkdir -p "$(dirname "$STATE_FILE")"
    printf '%s\n' "$GPU_FAMILY" > "$STATE_FILE"
}

# ── Helper functions ──────────────────────────────────────────

IsInstalled() { pacman -Qq "$1" &>/dev/null; }

HasRepo() { grep -q "^\[$1\]" /etc/pacman.conf; }

PkgAvailableInRepos() { pacman -Si "$1" &>/dev/null; }

# ── GPU Detection ─────────────────────────────────────────────

DetectGPU() {
    # Try class 0300 (VGA) and 0302 (3D) explicitly, then fallback
    GPU_RAW=$(lspci -d 10de::0300 2>/dev/null | head -n 1)
    [ -z "$GPU_RAW" ] && GPU_RAW=$(lspci -d 10de::0302 2>/dev/null | head -n 1)
    [ -z "$GPU_RAW" ] && GPU_RAW=$(lspci | grep -i "NVIDIA" | grep -iE "VGA|3D|Display" | head -n 1)

    # Extract 2-letter family code: TU, GA, AD, GB, GM, GP, GV, GK, GF ...
    GPU_FAMILY=$(echo "$GPU_RAW" | sed -E 's|.*NVIDIA Corporation ([A-Z]{2})[0-9A-Z]+ .*|\1|')
    GPU_NAME=$(echo   "$GPU_RAW" | sed -E 's|.*NVIDIA Corporation ([^[]+).*|\1|' | xargs)

    # lspci on some systems shows vendor string differently — second attempt
    if [ -z "$GPU_FAMILY" ] || [ ${#GPU_FAMILY} -ne 2 ]; then
        GPU_FAMILY=$(echo "$GPU_RAW" | grep -oP '(?<=NVIDIA Corporation )[A-Z]{2}')
    fi
}

# Detects Optimus: laptop with integrated iGPU (Intel/AMD) + NVIDIA dGPU.
DetectOptimus() {
    OPTIMUS=no
    local igpu
    igpu=$(lspci | grep -iE "VGA|3D|Display" | grep -iv "NVIDIA")
    [ -n "$igpu" ] && OPTIMUS=yes
}

FamilyName() {
    case "$1" in
        TU) echo "Turing (RTX 20xx / GTX 16xx)" ;;
        GA) echo "Ampere (RTX 30xx)" ;;
        AD) echo "Ada Lovelace (RTX 40xx)" ;;
        GB) echo "Blackwell (RTX 50xx)" ;;
        GN) echo "Next-gen" ;;
        GV) echo "Volta (Titan V / Quadro)" ;;
        GM) echo "Maxwell (GTX 750 / 900 / 9xxM laptops)" ;;
        GP) echo "Pascal (GTX 10xx / 10xxM laptops)" ;;
        GK) echo "Kepler (GTX 600/700 / GT 7xxM laptops)" ;;
        GF) echo "Fermi (GT 400/500 / GT 5xxM laptops)" ;;
        *)  echo "Unknown / very old (nouveau recommended)" ;;
    esac
}

# ── Driver Selection ──────────────────────────────────────────

SelectDriver() {
    DRIVER_TYPE=""
    DRIVER_PKG=""
    DRIVER_UTILS_PKG="nvidia-utils"
    GPU_GENERATION=""

    # --nouveau override always wins
    if [ "$MODE" = "nouveau" ]; then
        DRIVER_TYPE="nouveau"
        return
    fi

    case "$GPU_FAMILY" in
        TU*|GA*|AD*|GB*|GN*)
            # Turing and newer → official open-source kernel driver
            DRIVER_TYPE="open"
            DRIVER_PKG="nvidia-open-dkms"
            DRIVER_UTILS_PKG="nvidia-utils"
            GPU_GENERATION="modern"
            ;;
        GM*|GP*|GV*)
            # Maxwell / Pascal / Volta → stable proprietary driver
            DRIVER_TYPE="proprietary"
            DRIVER_PKG="nvidia-open-dkms"
            DRIVER_UTILS_PKG="nvidia-utils"
            GPU_GENERATION="legacy"
            ;;
        GK*)
            # Kepler (GTX 600/700, GT 7xxM laptops) → nvidia-470xx-dkms
            # Available in offline cache or AUR
            DRIVER_TYPE="open"
            DRIVER_PKG="nvidia-470xx-dkms"
            DRIVER_UTILS_PKG="nvidia-470xx-utils"
            GPU_GENERATION="kepler"
            ;;
        GF*)
            # Fermi (GT 400/500, GT 5xxM laptops e.g. GT 540M) → nvidia-390xx-dkms
            # Available in offline cache or AUR
            DRIVER_TYPE="open"
            DRIVER_PKG="nvidia-390xx-dkms"
            DRIVER_UTILS_PKG="nvidia-390xx-utils"
            GPU_GENERATION="fermi"
            ;;
        "")
            if [ "$FORCE" = yes ]; then
                Warn "No NVIDIA GPU detected, proceeding because --force is set."
                DRIVER_TYPE="open"
                DRIVER_PKG="nvidia-open-dkms"
                DRIVER_UTILS_PKG="nvidia-utils"
            elif [ "$AUTO" = yes ]; then
                Note "No NVIDIA GPU detected — skipping NVIDIA driver setup."
                DRIVER_TYPE="skip"
            else
                DIE "No NVIDIA GPU detected.\n       Use --force to override, or --nouveau for the nouveau driver."
            fi
            ;;
        *)
            # Older than Fermi (G8x, G9x, etc.) — nouveau only
            DRIVER_TYPE="nouveau"
            ;;
    esac

    # --no-dkms: only applicable to nvidia-open-dkms; legacy AUR packages are DKMS-only
    if [ "$NO_DKMS" = yes ] && [ "$DRIVER_PKG" = "nvidia-open-dkms" ]; then
        DRIVER_PKG="nvidia-open"
        Note "--no-dkms: using 'nvidia-open' instead of 'nvidia-open-dkms'."
        Note "  Only linux/linux-lts are supported without DKMS."
    elif [ "$NO_DKMS" = yes ] && [ "$DRIVER_TYPE" = "open" ]; then
        Note "--no-dkms: ignored for $DRIVER_PKG (DKMS-only package)."
    fi
}

# ── Kernel Headers ────────────────────────────────────────────

CollectKernelHeaders() {
    HEADERS_TO_INSTALL=()
    [ "$NO_DKMS" = yes ] && return

    local kernels=(linux linux-lts linux-zen linux-hardened linux-rt linux-rt-lts)
    for k in "${kernels[@]}"; do
        if IsInstalled "$k" && ! IsInstalled "${k}-headers"; then
            HEADERS_TO_INSTALL+=("${k}-headers")
            Info "Will install ${k}-headers (DKMS requirement)"
        fi
    done
}

# ── Offline cache lookup ──────────────────────────────────────
# Finds the newest cached .pkg.tar.zst for a given package name.
# Returns the path, or empty string if not found.
FindCachedPkg() {
    local name="$1"
    [ -d "$DRIVER_CACHE_DIR" ] || return
    ls -t "$DRIVER_CACHE_DIR/${name}-"*.pkg.tar.zst 2>/dev/null | head -n 1
}

# ── Package Lists ─────────────────────────────────────────────

BuildPackageLists() {
    INSTALL=()
    REMOVE=()

    if [ "$DRIVER_TYPE" = "nouveau" ]; then
        INSTALL+=(vulkan-nouveau)
        HasRepo multilib && [ "$BIT32" = yes ] && INSTALL+=(lib32-vulkan-nouveau)

        # Remove all conflicting proprietary packages
        local rm_list=(
            nvidia-open-dkms nvidia-open nvidia-open-lts nvidia-dkms nvidia-utils
            nvidia-470xx-dkms nvidia-470xx-utils
            nvidia-390xx-dkms nvidia-390xx-utils
            nvidia-settings nvidia-hook pg-nvidia-hook
        )
        for p in "${rm_list[@]}"; do
            IsInstalled "$p" && REMOVE+=("$p")
        done

    else
        # Main driver + utils
        INSTALL+=("$DRIVER_PKG" "$DRIVER_UTILS_PKG")

        # nvidia-settings: only for modern/legacy (open-dkms era), not legacy AUR
        if [ "$SETTINGS_PKG" = yes ] && [ "$GPU_GENERATION" != "fermi" ] && [ "$GPU_GENERATION" != "kepler" ]; then
            INSTALL+=(nvidia-settings)
        fi

        # Hook package (our own preferred, fallback to EndeavourOS)
        if PkgAvailableInRepos pg-nvidia-hook; then
            INSTALL+=(pg-nvidia-hook)
        elif PkgAvailableInRepos nvidia-hook; then
            INSTALL+=(nvidia-hook)
            Note "pg-nvidia-hook not found — using nvidia-hook from EndeavourOS repos."
        else
            Warn "No nvidia hook package found. Initramfs won't auto-rebuild on driver updates."
        fi

        # 32-bit support: lib32 package name differs by driver series
        if HasRepo multilib && [ "$BIT32" = yes ]; then
            case "$GPU_GENERATION" in
                modern|legacy) INSTALL+=(lib32-nvidia-utils) ;;
                # 470xx / 390xx don't have official lib32 packages in AUR
                *) Note "32-bit libs not available for $DRIVER_PKG — skipping." ;;
            esac
        fi

        # DKMS + headers
        if [ "$NO_DKMS" = no ]; then
            IsInstalled dkms || INSTALL+=(dkms)
            INSTALL+=("${HEADERS_TO_INSTALL[@]}")
        fi

        # Remove conflicting drivers (everything except what we're about to install)
        local rm_list=(xf86-video-nouveau vulkan-nouveau lib32-vulkan-nouveau)
        case "$DRIVER_PKG" in
            nvidia-open-dkms|nvidia-open|nvidia-open-lts|nvidia-dkms)
                rm_list+=(nvidia-470xx-dkms nvidia-470xx-utils nvidia-390xx-dkms nvidia-390xx-utils)
                ;;
            nvidia-470xx-dkms)
                rm_list+=(nvidia-open-dkms nvidia-open nvidia-open-lts nvidia-utils nvidia-390xx-dkms nvidia-390xx-utils)
                ;;
            nvidia-390xx-dkms)
                rm_list+=(nvidia-open-dkms nvidia-open nvidia-open-lts nvidia-utils nvidia-470xx-dkms nvidia-470xx-utils)
                ;;
        esac
        for p in "${rm_list[@]}"; do
            IsInstalled "$p" && REMOVE+=("$p")
        done
    fi

    # Remove already-installed from INSTALL list
    local filtered=()
    for p in "${INSTALL[@]}"; do
        [ -z "$p" ] && continue
        IsInstalled "$p" || filtered+=("$p")
    done
    INSTALL=("${filtered[@]}")

    readarray -t REMOVE < <(printf "%s\n" "${REMOVE[@]}" | sort -u)
}

# ── Nouveau Blacklist ─────────────────────────────────────────

ConfigureNouveauBlacklist() {
    local conf=/etc/modprobe.d/blacklist-nouveau.conf

    if [ "$DRIVER_TYPE" = "nouveau" ]; then
        if [ -f "$conf" ]; then
            Info "Removing nouveau blacklist (using nouveau driver)"
            [ "$DRY_RUN" = no ] && rm -f "$conf"
        fi
        return
    fi

    if [ -f "$conf" ] && grep -q "blacklist nouveau" "$conf"; then
        Info "Nouveau blacklist already set in $conf"
        return
    fi

    Info "Writing nouveau blacklist → $conf"
    if [ "$DRY_RUN" = no ]; then
        printf 'blacklist nouveau\noptions nouveau modeset=0\n' > "$conf"
    else
        Note "[DRY RUN] Would write nouveau blacklist → $conf"
    fi
}

# ── Wayland DRM Modeset ───────────────────────────────────────
#
#  Per-generation options:
#
#  modern  (TU+, nvidia-open-dkms 560+):
#    modeset=1 fbdev=1, PreserveVideoMemoryAllocations=1
#
#  legacy  (GM/GP/GV, nvidia-open-dkms 560+):
#    modeset=1 fbdev=1, PreserveVideoMemoryAllocations=1, EnableGpuFirmware=0
#
#  kepler  (GK, nvidia-470xx-dkms):
#    modeset=1 (no fbdev — not supported), EnableGpuFirmware=0
#
#  fermi   (GF, nvidia-390xx-dkms, e.g. GT 540M):
#    modeset=1 (no fbdev, no PreserveVideoMemory — may cause issues on 390xx)
#    EnableGpuFirmware=0

ConfigureWayland() {
    [ "$DRIVER_TYPE" = "nouveau" ] && return

    local conf=/etc/modprobe.d/nvidia.conf

    Info "Writing NVIDIA modprobe config → $conf"
    if [ "$DRY_RUN" = no ]; then
        {
            # DRM modeset: required for Wayland and PRIME on all proprietary drivers
            # fbdev=1: enables fbdev framebuffer — only supported on open-dkms 560+ era
            if [ "$GPU_GENERATION" = "modern" ] || [ "$GPU_GENERATION" = "legacy" ]; then
                printf 'options nvidia_drm modeset=1 fbdev=1\n'
            else
                printf 'options nvidia_drm modeset=1\n'
            fi

            # Suspend memory preservation: open-dkms and 470xx (not 390xx — may be unstable)
            if [ "$GPU_GENERATION" = "modern" ] || [ "$GPU_GENERATION" = "legacy" ] || [ "$GPU_GENERATION" = "kepler" ]; then
                printf 'options nvidia NVreg_PreserveVideoMemoryAllocations=1\n'
            fi

            # Disable GSP firmware for all non-Turing+ generations
            if [ "$GPU_GENERATION" != "modern" ]; then
                printf 'options nvidia NVreg_EnableGpuFirmware=0\n'
            fi
        } > "$conf"
    else
        Note "[DRY RUN] Would write nvidia modprobe options → $conf  (generation: $GPU_GENERATION)"
    fi

    # Wayland environment: GBM backend and GLX vendor override
    local envconf=/etc/environment.d/99-nvidia-wayland.conf
    if [ -f "$envconf" ]; then
        Info "NVIDIA Wayland environment already set in $envconf"
        return
    fi

    Info "Writing NVIDIA Wayland environment → $envconf"
    if [ "$DRY_RUN" = no ]; then
        mkdir -p /etc/environment.d
        printf 'GBM_BACKEND=nvidia-drm\n__GLX_VENDOR_LIBRARY_NAME=nvidia\n' > "$envconf"
    else
        Note "[DRY RUN] Would write NVIDIA Wayland env → $envconf"
    fi
}

# ── NVIDIA Suspend/Resume Services ───────────────────────────

EnableNvidiaSleepServices() {
    [ "$DRIVER_TYPE" = "nouveau" ] && return

    # Suspend services only exist in the nvidia-open-dkms package
    [ "$GPU_GENERATION" = "kepler" ] && return
    [ "$GPU_GENERATION" = "fermi"  ] && return

    [ "$DRY_RUN" = yes ] && { Note "[DRY RUN] Would enable nvidia suspend/resume/hibernate services"; return; }

    local services=(nvidia-suspend.service nvidia-resume.service nvidia-hibernate.service)
    for svc in "${services[@]}"; do
        if systemctl list-unit-files "$svc" &>/dev/null; then
            systemctl enable "$svc" 2>/dev/null \
                && Info "Enabled $svc" \
                || Warn "Could not enable $svc"
        fi
    done
}

# ── initramfs module configuration ───────────────────────────
# Supports both mkinitcpio and dracut automatically.

DetectInitramfsTool() {
    if [ -f /etc/mkinitcpio.conf ]; then
        echo "mkinitcpio"
    elif command -v dracut &>/dev/null; then
        echo "dracut"
    else
        echo "unknown"
    fi
}

ConfigureMkinitcpio() {
    [ "$DRIVER_TYPE" = "nouveau" ] && return

    local tool
    tool=$(DetectInitramfsTool)

    case "$tool" in
        mkinitcpio) ConfigureMkinitcpioModules ;;
        dracut)     ConfigureDracut ;;
        *)
            Warn "No supported initramfs tool found (mkinitcpio or dracut)."
            Warn "  Add nvidia modules manually before rebooting!"
            ;;
    esac
}

ConfigureMkinitcpioModules() {
    local conf=/etc/mkinitcpio.conf
    local need="nvidia nvidia_modeset nvidia_uvm nvidia_drm"

    local current_line
    current_line=$(grep "^MODULES=" "$conf")
    [ -z "$current_line" ] && { Warn "MODULES= line not found in $conf."; return; }

    local missing=()
    for mod in $need; do
        echo "$current_line" | grep -q "\b$mod\b" || missing+=("$mod")
    done

    if [ ${#missing[@]} -eq 0 ]; then
        Info "NVIDIA modules already in mkinitcpio MODULES=() — no changes."
        return
    fi

    Info "Adding to mkinitcpio MODULES: ${missing[*]}"
    if [ "$DRY_RUN" = no ]; then
        local existing
        existing=$(echo "$current_line" | sed -E 's|^MODULES=\(([^)]*)\)|\1|')
        local combined
        combined=$(echo "$existing ${missing[*]}" | tr -s ' ' | sed 's/^ //')
        sed -i "s|^MODULES=(.*)|MODULES=($combined)|" "$conf"
        Info "Updated: MODULES=($combined)"
    else
        Note "[DRY RUN] Would add to mkinitcpio MODULES=(): ${missing[*]}"
    fi
}

ConfigureDracut() {
    local conf=/etc/dracut.conf.d/nvidia.conf
    local line='force_drivers+=" nvidia nvidia_modeset nvidia_uvm nvidia_drm "'

    if [ -f "$conf" ] && grep -q "nvidia" "$conf"; then
        Info "NVIDIA dracut config already exists at $conf"
        return
    fi

    Info "Writing dracut NVIDIA config → $conf"
    if [ "$DRY_RUN" = no ]; then
        mkdir -p /etc/dracut.conf.d
        echo "$line" > "$conf"
    else
        Note "[DRY RUN] Would write: $line  →  $conf"
    fi
}

# ── Execute ───────────────────────────────────────────────────
# Installs a single package: tries offline cache first, falls back to pacman -S.

InstallPkg() {
    local pkg="$1"
    local cached
    cached=$(FindCachedPkg "$pkg")
    if [ -n "$cached" ]; then
        Info "  Installing from cache: $(basename "$cached")"
        pacman -U --needed --noconfirm "$cached"
    else
        pacman -S --needed --noconfirm "$pkg"
    fi
}

ExecuteChanges() {
    if [ ${#REMOVE[@]} -gt 0 ]; then
        Info "Removing conflicting packages: ${REMOVE[*]}"
        if [ "$DRY_RUN" = no ]; then
            pacman -Rns --noconfirm "${REMOVE[@]}" 2>/dev/null \
                || Warn "Some packages could not be removed (may be dependencies of others)."
        else
            Note "[DRY RUN] Would remove: ${REMOVE[*]}"
        fi
    fi

    if [ ${#INSTALL[@]} -gt 0 ]; then
        Info "Installing: ${INSTALL[*]}"
        if [ "$DRY_RUN" = no ]; then
            local failed=()
            for pkg in "${INSTALL[@]}"; do
                InstallPkg "$pkg" || failed+=("$pkg")
            done
            if [ ${#failed[@]} -gt 0 ]; then
                if [ "$AUTO" = yes ]; then
                    Warn "Some packages could not be installed: ${failed[*]}"
                    Warn "  Place pre-built packages in $DRIVER_CACHE_DIR/ to enable offline install."
                else
                    DIE "Package installation failed for: ${failed[*]}\nCheck the output above."
                fi
            fi
        else
            for pkg in "${INSTALL[@]}"; do
                local cached
                cached=$(FindCachedPkg "$pkg")
                if [ -n "$cached" ]; then
                    Note "[DRY RUN] Would install from cache: $(basename "$cached")"
                else
                    Note "[DRY RUN] Would install from repos:  $pkg"
                fi
            done
        fi
    fi

    if [ ${#INSTALL[@]} -eq 0 ] && [ ${#REMOVE[@]} -eq 0 ]; then
        Info "All packages are already up to date — nothing to do."
    fi
}

RebuildInitramfs() {
    [ "$DRIVER_TYPE" = "nouveau" ] && return

    local tool
    tool=$(DetectInitramfsTool)

    case "$tool" in
        mkinitcpio)
            Info "Rebuilding initramfs with mkinitcpio -P ..."
            if [ "$DRY_RUN" = no ]; then
                mkinitcpio -P || Warn "mkinitcpio reported issues. Check output above."
            else
                Note "[DRY RUN] Would run: mkinitcpio -P"
            fi
            ;;
        dracut)
            Info "Rebuilding initramfs with dracut ..."
            if [ "$DRY_RUN" = no ]; then
                for kver_path in /usr/lib/modules/*/pkgbase; do
                    [ -f "$kver_path" ] || continue
                    local kver
                    kver=$(basename "$(dirname "$kver_path")")
                    Info "  → kernel $kver"
                    dracut --force "/boot/initramfs-$kver.img" "$kver" \
                        || Warn "dracut failed for $kver"
                done
            else
                Note "[DRY RUN] Would run: dracut --force for each installed kernel"
            fi
            ;;
        *)
            Warn "Cannot rebuild initramfs — no supported tool found."
            Warn "  Run 'mkinitcpio -P' or 'dracut' manually before rebooting!"
            ;;
    esac
}

# ── Summary ───────────────────────────────────────────────────

ShowSummary() {
    Header "PG GPU Sync — Plan"
    printf "  %-16s %s\n" "GPU:"       "${GPU_NAME:-not detected}"
    printf "  %-16s %s\n" "Family:"    "${GPU_FAMILY:-unknown} — $(FamilyName "$GPU_FAMILY")"
    printf "  %-16s %s\n" "Optimus:"   "$([ "$OPTIMUS" = yes ] && echo "yes (laptop iGPU + NVIDIA dGPU)" || echo "no")"
    printf "  %-16s %s\n" "Driver:"    "${DRIVER_PKG:-none (nouveau)}"
    printf "  %-16s %s\n" "Mode:"      "$([ "$DRY_RUN" = yes ] && echo "DRY RUN" || ([ "$AUTO" = yes ] && echo "AUTO (unattended)" || echo "Interactive"))"
    echo ""
    [ ${#INSTALL[@]} -gt 0 ] && printf "  %-16s %s\n" "To install:" "${INSTALL[*]}"
    [ ${#REMOVE[@]}  -gt 0 ] && printf "  %-16s %s\n" "To remove:"  "${REMOVE[*]}"
    echo ""
}

# ── Help ──────────────────────────────────────────────────────

ShowHelp() {
    cat <<EOF

  pg-gpu-sync — Equestria OS NVIDIA Driver Manager
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Usage:  sudo pg-gpu-sync [options]

  Options:
    -h, --help          This help.
    -t, --test          Dry run — show what WOULD happen, change nothing.
    -a, --auto          Unattended mode for OS installer / live image.
                        No prompts. Legacy GPU packages must be in cache.
    -f, --force         Install even if no NVIDIA GPU detected.
    -n, --nouveau       Force the open-source nouveau driver.
        --no-dkms       Use non-DKMS package (nvidia-open only, linux/linux-lts).
        --32            Add 32-bit support (Steam/Proton).
                        Requires [multilib] in /etc/pacman.conf.
        --no-settings   Skip nvidia-settings.
        --show-gpu      Print detected GPU info and exit.

  GPU support:
    Turing / Ampere / Ada / Blackwell  →  nvidia-open-dkms     (official repos)
    Maxwell / Pascal / Volta           →  nvidia-open-dkms     (official repos)
    Kepler  (GTX 600/700, GT 7xxM)    →  nvidia-470xx-dkms    (offline cache / AUR)
    Fermi   (GT 400/500, GT 5xxM)     →  nvidia-390xx-dkms    (offline cache / AUR)
    Older                              →  nouveau

  Offline cache:
    Place pre-built .pkg.tar.zst files in:
      $DRIVER_CACHE_DIR/
    Packages found there are installed with 'pacman -U' (no internet required).
    Useful for ISO images and installer auto mode.

EOF
}

# ── Options Parsing ───────────────────────────────────────────

ParseOptions() {
    FORCE=no
    DRY_RUN=no
    AUTO=no
    MODE="nvidia"
    NO_DKMS=no
    BIT32=no
    SETTINGS_PKG=yes

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)        ShowHelp; exit 0 ;;
            -t|--test)        DRY_RUN=yes ;;
            -a|--auto)        AUTO=yes ;;
            -f|--force)       FORCE=yes ;;
            -n|--nouveau)     MODE=nouveau ;;
            --no-dkms)        NO_DKMS=yes ;;
            --32)             BIT32=yes ;;
            --no-settings)    SETTINGS_PKG=no ;;
            --show-gpu)
                DetectGPU
                DetectOptimus
                echo "GPU     : ${GPU_NAME:-not detected}"
                echo "Family  : ${GPU_FAMILY:-unknown} — $(FamilyName "$GPU_FAMILY")"
                echo "Optimus : $([ "$OPTIMUS" = yes ] && echo "yes (iGPU + NVIDIA dGPU)" || echo "no")"
                exit 0
                ;;
            *) Warn "Unknown option: $1"; ShowHelp; exit 1 ;;
        esac
        shift
    done
}

# ── Main ──────────────────────────────────────────────────────

Main() {
    ParseOptions "$@"

    [ "$EUID" -ne 0 ] && DIE "Please run as root:  sudo pg-gpu-sync $*"

    Header "PG GPU Sync — Equestria OS"

    # 1. Detect GPU hardware
    Info "Scanning for NVIDIA GPU..."
    DetectGPU
    DetectOptimus

    [ -n "$GPU_NAME" ] && Info "Detected: $GPU_NAME  [family: ${GPU_FAMILY:-?}]"
    [ "$OPTIMUS" = yes ] && Info "Optimus detected — laptop with iGPU + NVIDIA dGPU"

    # 2. Choose the right driver
    SelectDriver

    # Skip entirely if no NVIDIA GPU in auto mode
    [ "$DRIVER_TYPE" = "skip" ] && { SaveGpuState; Info "Skipping NVIDIA driver installation."; exit 0; }

    # Fast path in --auto mode: skip if GPU hasn't changed
    if [ "$AUTO" = yes ] && [ "$DRY_RUN" = no ]; then
        if ! GpuChanged; then
            Info "GPU unchanged ($(FamilyName "$GPU_FAMILY")) — driver already configured."
            exit 0
        fi
        [ -f "$STATE_FILE" ] && _GPU_WAS_SWAPPED=yes || _GPU_WAS_SWAPPED=no
    fi

    # 3. Find which kernel headers are missing
    CollectKernelHeaders

    # 4. Build install/remove lists
    BuildPackageLists

    # 5. Show the plan
    ShowSummary

    # 6. Confirm (skip in auto/dry-run mode)
    if [ "$DRY_RUN" = no ] && [ "$AUTO" = no ]; then
        read -rp "  Proceed? [Y/n] " confirm
        [[ "$confirm" =~ ^[Nn]$ ]] && { Info "Aborted."; exit 0; }
        echo ""
    fi

    # 7. Remove conflicting packages + install new ones
    ExecuteChanges

    # 8. Nouveau blacklist
    ConfigureNouveauBlacklist

    # 9. Wayland modeset config (generation-aware)
    ConfigureWayland

    # 10. Enable nvidia suspend/resume/hibernate systemd services
    EnableNvidiaSleepServices

    # 11. mkinitcpio/dracut MODULES injection
    ConfigureMkinitcpio

    # 12. Rebuild initramfs
    RebuildInitramfs

    SaveGpuState

    Header "Done!"
    if [ "$DRY_RUN" = yes ]; then
        Note "Dry run complete — nothing was changed on your system."
    elif [ "$AUTO" = yes ] && [ "${_GPU_WAS_SWAPPED:-no}" = yes ]; then
        Info "GPU was swapped — rebooting in 5 seconds to apply new driver..."
        sleep 5
        systemctl reboot
    else
        Info "Done. Please reboot."
        Info "  sudo reboot"
    fi
}

Main "$@"
