# Maintainer: Equestria OS Team

pkgname=equestria-os-welcome-hub
pkgver=2.2.0
pkgrel=1
pkgdesc="The official Equestria OS Welcome Center and Community Portal"
arch=('any')
url="https://github.com/7Lucia7Lokidottir7"
license=('GPL')
depends=('python' 'python-pyqt6' 'xdg-utils')

package() {
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/bin"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    cp "$startdir/welcome_hub.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/ui_welcome.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/style.qss" "$pkgdir/opt/$pkgname/"
    cp "$startdir/equestria_cyrillic.ttf" "$pkgdir/opt/$pkgname/"
    cp "$startdir/EquestriaOS-Logo.png" "$pkgdir/opt/$pkgname/"

    if [ -f "$startdir/start.sh" ]; then
        cp "$startdir/start.sh" "$pkgdir/opt/$pkgname/"
        chmod 755 "$pkgdir/opt/$pkgname/start.sh"
    fi

    chmod 755 "$pkgdir/opt/$pkgname/welcome_hub.py"

    echo "#!/bin/bash" > "$pkgdir/usr/bin/equestria-welcome"
    echo "python3 /opt/$pkgname/welcome_hub.py \"\$@\"" >> "$pkgdir/usr/bin/equestria-welcome"
    chmod 755 "$pkgdir/usr/bin/equestria-welcome"

    install -Dm644 "$startdir/equestria-os-welcome.desktop" "$pkgdir/usr/share/applications/"

    # Уникальное имя иконки: equestria-os-welcome-hub.png
    install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/equestria-os-welcome-hub.png"
}
