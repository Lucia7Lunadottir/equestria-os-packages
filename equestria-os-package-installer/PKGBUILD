# Maintainer: Equestria OS Team

pkgname=equestria-os-package-installer
pkgver=2.0.4
pkgrel=1
pkgdesc='The official Equestria OS app and driver store'
arch=('any')
url='https://psyche-games.com'
license=('custom')
depends=('python' 'python-pyqt6' 'polkit' 'konsole')

package() {
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    cp "$startdir/main.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/ui_store.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/style.qss" "$pkgdir/opt/$pkgname/"
    cp "$startdir/equestria_cyrillic.ttf" "$pkgdir/opt/$pkgname/"
    cp "$startdir/EquestriaApps.csv" "$pkgdir/opt/$pkgname/"
    cp "$startdir/EquestriaLocalizations.csv" "$pkgdir/opt/$pkgname/"
    cp "$startdir/EquestriaOS-Logo.png" "$pkgdir/opt/$pkgname/"

    if [ -f "$startdir/start.sh" ]; then
        cp "$startdir/start.sh" "$pkgdir/opt/$pkgname/"
        chmod 755 "$pkgdir/opt/$pkgname/start.sh"
    fi

    chmod 755 "$pkgdir/opt/$pkgname/main.py"

    if [ -f "$startdir/equestria-app-store.desktop" ]; then
        install -Dm644 "$startdir/equestria-app-store.desktop" "$pkgdir/usr/share/applications/equestria-app-store.desktop"
    elif [ -f "$startdir/equestria-os-package-manager.desktop" ]; then
        install -Dm644 "$startdir/equestria-os-package-manager.desktop" "$pkgdir/usr/share/applications/equestria-app-store.desktop"
    fi

    # Уникальное имя иконки: equestria-app-store.png
    install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/equestria-app-store.png"
}
