# Maintainer: Equestria OS Team

pkgname=equestria-os-swap-manager
pkgver=1.0.0
pkgrel=3
pkgdesc="GUI tool for managing swap files, partitions, and swappiness"
arch=('any')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('python' 'python-pyqt6' 'polkit')
optdepends=(
    'kdesu: alternative privilege elevation'
)

post_install() {
    kbuildsycoca6 --noincremental || true
}

package() {
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/bin"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    # Python files (вернули core.py!)
    install -Dm644 "$startdir/swap_app.py"     "$pkgdir/opt/$pkgname/swap_app.py"
    install -Dm644 "$startdir/swap_backend.py" "$pkgdir/opt/$pkgname/swap_backend.py"
    install -Dm644 "$startdir/core.py"         "$pkgdir/opt/$pkgname/core.py"
    install -Dm644 "$startdir/privilege.py"    "$pkgdir/opt/$pkgname/privilege.py"
    install -Dm644 "$startdir/style.qss"       "$pkgdir/opt/$pkgname/style.qss"

    # Assets
    install -Dm644 "$startdir/equestria_cyrillic.ttf" "$pkgdir/opt/$pkgname/equestria_cyrillic.ttf"
    install -Dm644 "$startdir/equestria-os-swap-manager.png"   "$pkgdir/opt/$pkgname/equestria-os-swap-manager.png"

    # Wrapper script
    cat > "$pkgdir/usr/bin/equestria-swap-manager" <<'EOF'
#!/bin/bash
cd /opt/equestria-os-swap-manager
python3 swap_app.py "$@"
EOF
    chmod 755 "$pkgdir/usr/bin/equestria-swap-manager"

    # Desktop entry
    install -Dm644 "$startdir/equestria-os-swap-manager.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-swap-manager.desktop"

    # Icon
    install -Dm644 "$startdir/equestria-os-swap-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-swap-manager.png"
}
