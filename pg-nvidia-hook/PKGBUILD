# Maintainer: Equestria OS Team <your@email.here>

pkgname=pg-nvidia-hook
pkgver=1.0.3
pkgrel=1
pkgdesc='Pacman hook for NVIDIA — auto-rebuilds initramfs after driver updates (Equestria OS)'
arch=('any')
license=('GPL3')
url='https://psyche-games.com'
depends=('bash' 'mkinitcpio')
conflicts=('nvidia-hook' 'eos-nvidia-fix')
# Note: no dependency on expac or eos-* tools

source=(
    'pg-nvidia-fix'
    'pg-nvidia-fix.hook'
)
sha256sums=('SKIP'
            'SKIP')

package() {
    install -Dm755 pg-nvidia-fix      "$pkgdir/usr/bin/pg-nvidia-fix"
    install -Dm644 pg-nvidia-fix.hook "$pkgdir/usr/share/libalpm/hooks/pg-nvidia-fix.hook"
}
