pkgname=equestria-os-software-center
pkgver=1.0
pkgrel=1
pkgdesc="Центр программного обеспечения для Equestria OS (Essentials + App Store)"
arch=('any')
url="https://github.com/equestria-os/equestria-os-software-center"
license=('GPL')
depends=('python' 'python-pyqt6' 'pacman' 'yay')

# Список всех файлов, которые должны быть в папке рядом с PKGBUILD при сборке
source=(
    'main.py'
    'ui_software.py'
    'style.qss'
    'equestria_cyrillic.ttf'
    'EquestriaApps.csv'
    'EquestriaLocalizations.csv'
    'equestria-app-store.desktop'
    'equestria-os-software-center.png'
)

sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    # Создаем папку приложения в /usr/share/
    install -d "$pkgdir/usr/share/equestria-os-software-center"

    # Копируем код и ресурсы
    install -m644 main.py "$pkgdir/usr/share/equestria-os-software-center/main.py"
    install -m644 ui_software.py "$pkgdir/usr/share/equestria-os-software-center/ui_software.py"
    install -m644 style.qss "$pkgdir/usr/share/equestria-os-software-center/style.qss"
    install -m644 equestria_cyrillic.ttf "$pkgdir/usr/share/equestria-os-software-center/equestria_cyrillic.ttf"
    install -m644 EquestriaApps.csv "$pkgdir/usr/share/equestria-os-software-center/EquestriaApps.csv"
    install -m644 EquestriaLocalizations.csv "$pkgdir/usr/share/equestria-os-software-center/EquestriaLocalizations.csv"

    # Устанавливаем иконку в системную папку иконок
    install -Dm644 equestria-os-software-center.png "$pkgdir/usr/share/pixmaps/equestria-os-software-center.png"

    # Устанавливаем .desktop файл
    install -Dm644 equestria-app-store.desktop "$pkgdir/usr/share/applications/equestria-os-software-center.desktop"
}
