# Maintainer: Equestria OS Team

pkgname=equestria-os-package-manager
pkgver=1.0.1
pkgrel=1
pkgdesc='Official Equestria OS Package Manager (Uninstall and Manage)'
arch=('x86_64')
url='https://psyche-games.com'
license=('custom')
options=('!strip') # КРИТИЧЕСКИ ВАЖНО: не ломать бинарники Unity

package() {
    # 1. Создаем системные папки
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    # 2. Копируем файлы программы (исполняемый, библиотеки и папку Data)
    cp -r "$startdir/Equestria OS Package Manager.x86_64" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/Equestria OS Package Manager_Data" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/"*.so "$pkgdir/opt/$pkgname/"

    # 3. Выдаем файлам права на исполнение
    chmod 755 "$pkgdir/opt/$pkgname/Equestria OS Package Manager.x86_64"
    chmod 755 "$pkgdir/opt/$pkgname/"*.so

    # 4. Копируем ярлык для меню приложений
    install -Dm644 "$startdir/equestria-os-package-manager.desktop" "$pkgdir/usr/share/applications/"

    # 5. Копируем твой логотип как иконку системы
    install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/equestria-os-package-manager.png"
}
