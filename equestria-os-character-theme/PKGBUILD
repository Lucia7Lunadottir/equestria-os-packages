# Maintainer: Equestria OS Team

pkgname=equestria-os-character-theme
pkgver=1.2.0
pkgrel=1
pkgdesc='Customizing the visual style and characters of Equestria OS'
arch=('x86_64')
url='https://psyche-games.com'
license=('custom')
options=('!strip') # КРИТИЧЕСКИ ВАЖНО: не ломать бинарники Unity

package() {
    # 1. Создаем системные папки
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    # 2. Копируем файлы программы (исполняемый, библиотеки и папку Data)
    cp -r "$startdir/Equestria OS Character Theme.x86_64" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/Equestria OS Character Theme_Data" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/"*.so "$pkgdir/opt/$pkgname/"

    # 3. Выдаем файлам права на исполнение
    chmod 755 "$pkgdir/opt/$pkgname/Equestria OS Character Theme.x86_64"
    chmod 755 "$pkgdir/opt/$pkgname/"*.so

    # 4. Копируем ярлык для меню приложений
    install -Dm644 "$startdir/equestria-os-character-theme.desktop" "$pkgdir/usr/share/applications/"

}
