#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Equestria OS Theme Switcher
Name[en]=Equestria OS Theme Switcher
Name[ru]=Переключатель тем Equestria OS
Name[de]=Equestria-OS-Theme-Wechsler
Name[fr]=Sélecteur de thèmes Equestria OS
