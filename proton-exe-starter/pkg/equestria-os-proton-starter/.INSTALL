post_install() {
    # Rebuild KDE sycoca cache for each logged-in user so the
    # right-click service menu appears in Dolphin without re-login.
    if command -v kbuildsycoca6 &>/dev/null; then
        local user uid
        while IFS=: read -r user _ uid _; do
            [[ $uid -ge 1000 ]] || continue
            local xdg_runtime="/run/user/$uid"
            if [[ -d "$xdg_runtime" ]]; then
                sudo -u "$user" \
                    DBUS_SESSION_BUS_ADDRESS="unix:path=$xdg_runtime/bus" \
                    kbuildsycoca6 --noincremental &>/dev/null || true
            fi
        done < /etc/passwd
    fi
}

post_upgrade() {
    post_install
}

post_remove() {
    post_install
}
