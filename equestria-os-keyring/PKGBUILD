# Maintainer: Equestria OS Team

pkgname=equestria-os-keyring
pkgver=20260227
pkgrel=3
pkgdesc="Digital trust keys for Equestria OS"
arch=('any')
url="https://github.com/7Lucia7Lokidottir7"
license=('GPL')
install="equestria-os-keyring.install"

source=('equestria-os.gpg'
        'equestria-os-trusted'
        'equestria-os-revoked')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    install -d "$pkgdir/usr/share/pacman/keyrings/"
    install -m644 equestria-os.gpg "$pkgdir/usr/share/pacman/keyrings/"
    install -m644 equestria-os-trusted "$pkgdir/usr/share/pacman/keyrings/"
    install -m644 equestria-os-revoked "$pkgdir/usr/share/pacman/keyrings/"
}
