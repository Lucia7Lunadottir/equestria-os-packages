# Игнорируем готовые собранные пакеты (Их мы будем заливать вручную в Releases)
*.pkg.tar.zst
*.tar.gz
*.zip

# --- ИСКЛЮЧЕНИЯ ДЛЯ НАШЕГО РЕПОЗИТОРИЯ ---
# Разрешаем Git'у видеть пакеты и базы именно внутри папки x86_64
!x86_64/*.pkg.tar.zst
!x86_64/*.db
!x86_64/*.db.tar.gz
!x86_64/*.files
!x86_64/*.files.tar.gz
