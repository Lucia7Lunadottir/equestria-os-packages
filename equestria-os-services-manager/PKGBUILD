# Maintainer: Equestria OS Team

pkgname=equestria-os-services-manager
pkgver=2.1.0
pkgrel=1
pkgdesc='Official Equestria OS Service Manager (Enable, Disable, Start, Stop)'
arch=('any')
url='https://psyche-games.com'
license=('custom')
depends=('python' 'python-pyqt6' 'polkit')

package() {
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    cp "$startdir/main.py"              "$pkgdir/opt/$pkgname/"
    cp "$startdir/ui_services.py"       "$pkgdir/opt/$pkgname/"
    cp "$startdir/style.qss"            "$pkgdir/opt/$pkgname/"
    cp "$startdir/equestria_cyrillic.ttf" "$pkgdir/opt/$pkgname/"
    cp "$startdir/equestria-os-services-manager.png" "$pkgdir/opt/$pkgname/"

    if [ -f "$startdir/start.sh" ]; then
        cp "$startdir/start.sh" "$pkgdir/opt/$pkgname/"
        chmod 755 "$pkgdir/opt/$pkgname/start.sh"
    fi

    chmod 755 "$pkgdir/opt/$pkgname/main.py"

    install -Dm644 "$startdir/equestria-os-services-manager.desktop" \
        "$pkgdir/usr/share/applications/"

    install -Dm644 "$startdir/equestria-os-services-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-services-manager.png"
}
